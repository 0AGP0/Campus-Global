---
import "../styles/global.css";
import { SiteHeader } from "@/components/layout/SiteHeader";
import { SiteFooter } from "@/components/layout/SiteFooter";

interface Props {
  title?: string;
  description?: string;
  /** Tam URL — kanonik ve og:url için */
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  /** Tam URL veya sitedeki mutlak yol (/ görsel.png) */
  ogImage?: string;
  ogType?: "website" | "article";
  twitterCard?: "summary_large_image" | "summary";
  keywords?: string;
  robots?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}

const {
  title = "Campus Global",
  description,
  canonicalUrl,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  twitterCard = "summary_large_image",
  keywords,
  robots = "index, follow",
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props as Props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description ?? "";
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {keywords ? <meta name="keywords" content={keywords} /> : null}
    <meta name="robots" content={robots} />
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    <meta property="og:title" content={resolvedOgTitle} />
    {resolvedOgDesc ? <meta property="og:description" content={resolvedOgDesc} /> : null}
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Campus Global" />
    {ogImage ? <meta property="og:image" content={ogImage} /> : null}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    {resolvedOgDesc ? <meta name="twitter:description" content={resolvedOgDesc} /> : null}
    {ogImage ? <meta name="twitter:image" content={ogImage} /> : null}
    {articlePublishedTime ? <meta property="article:published_time" content={articlePublishedTime} /> : null}
    {articleModifiedTime ? <meta property="article:modified_time" content={articleModifiedTime} /> : null}
    <slot name="head-extra" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top" class="flex min-h-dvh flex-col font-sans text-zap-ink">
    <SiteHeader client:load />
    <div class="flex min-h-0 flex-1 flex-col">
      <slot />
    </div>
    <SiteFooter />
  </body>
</html>
