---
import Layout from "@/layouts/Layout.astro";
import { getSiteOrigin } from "@/data/site-origin";
import { footerIletisim, preFooterSubeler } from "@/data/home-ia";

const title = "İletişim | Campus Global";
const description =
  "Campus Global ile telefon, e-posta ve şube bilgileri üzerinden yurtdışı eğitim danışmanlığı için iletişime geçin.";
const canonicalUrl = `${getSiteOrigin()}/iletisim`;
const telDigits = footerIletisim.tel.replace(/\D/g, "");
const telHref =
  telDigits.length >= 10
    ? `tel:+${telDigits.startsWith("90") ? telDigits : `90${telDigits}`}`
    : "#site-footer";
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogTitle="İletişim"
  ogDescription={description}
  ogType="website"
>
  <div
    class="min-h-dvh bg-gradient-to-br from-white via-[#e6faf8] to-brand-aqua/20 px-4 py-12 text-zap-ink sm:px-6 md:py-16"
  >
    <div class="mx-auto max-w-2xl">
      <p class="text-[11px] font-black uppercase tracking-[0.28em] text-brand-teal">Campus Global</p>
      <h1 class="mt-3 text-[clamp(1.65rem,4vw,2.1rem)] font-black uppercase leading-tight tracking-tight text-zap-night">
        İletişim
      </h1>
      <p class="mt-4 text-base font-medium leading-relaxed text-zap-ink/88">
        Yurtdışı dil okulu, üniversite ve yüksek lisans süreçleri için ekibimize aşağıdaki kanallardan ulaşabilirsiniz.
      </p>

      <div class="mt-10 space-y-6 rounded-2xl border-4 border-zap-ink bg-white p-6 shadow-brutal sm:p-8">
        <div>
          <p class="text-[11px] font-black uppercase tracking-[0.2em] text-brand-teal">Adres</p>
          <p class="mt-2 text-base font-semibold leading-relaxed text-zap-ink">{footerIletisim.adres}</p>
        </div>
        <div>
          <p class="text-[11px] font-black uppercase tracking-[0.2em] text-brand-teal">Telefon</p>
          <a
            href={telHref}
            class="mt-2 inline-flex min-h-12 items-center text-lg font-black text-zap-night underline-offset-4 hover:text-brand-teal hover:underline"
          >
            📱 {footerIletisim.tel}
          </a>
        </div>
        <div>
          <p class="text-[11px] font-black uppercase tracking-[0.2em] text-brand-teal">E-posta</p>
          <a
            href={`mailto:${footerIletisim.email}`}
            class="mt-2 inline-flex min-h-12 items-center text-lg font-bold text-zap-ink underline-offset-4 hover:text-brand-teal hover:underline"
          >
            📧 {footerIletisim.email}
          </a>
        </div>
        <p class="flex items-center gap-2 text-[14px] font-medium text-zap-ink/70">
          <span class="h-2 w-2 shrink-0 rounded-full bg-brand-aqua ring-2 ring-brand-aqua/30" aria-hidden />
          {footerIletisim.mesai}
        </p>
      </div>

      <div class="mt-10">
        <p class="text-[11px] font-black uppercase tracking-[0.2em] text-brand-teal">Şubeler</p>
        <ul class="mt-4 space-y-3">
          {
            preFooterSubeler.map((s) => (
              <li
                class="rounded-xl border-2 border-zap-ink/12 bg-white/80 px-4 py-3 text-[14px] font-semibold leading-snug text-zap-ink shadow-sm"
              >
                <span class="text-zap-night">{s.sehir}</span>
                <span class="text-zap-ink/60"> · </span>
                {s.ad}
              </li>
            ))
          }
        </ul>
      </div>

      <a
        href="/"
        class="mt-12 inline-flex min-h-12 items-center justify-center rounded-full border-4 border-zap-ink bg-zap-burst px-8 py-3 text-sm font-black uppercase text-zap-night shadow-brutal transition hover:brightness-105"
      >
        Ana sayfaya dön
      </a>
    </div>
  </div>
</Layout>
