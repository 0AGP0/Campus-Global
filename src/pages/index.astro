---
import Layout from "../layouts/Layout.astro";
import { HomeLanding } from "@/components/home/HomeLanding";
import { buildFaqPageJsonLd } from "@/data/home-ia";
import { SITE_CANONICAL_URL } from "@/config/site";

const faqJsonLd = JSON.stringify(buildFaqPageJsonLd(`${SITE_CANONICAL_URL}/`));
---

<Layout
  title="Yurtdışı Eğitim Danışmanlığı | Dil Okulu, Üniversite ve Yüksek Lisans | Campus Global"
  description="Campus Global ile yurtdışında dil okulu, üniversite ve yüksek lisans danışmanlığı: IELTS, TOEFL, SAT ve GRE/GMAT planı, ülke rehberleri ve şeffaf başvuru süreci."
>
  <div
    class="relative flex min-h-0 flex-1 flex-col overflow-x-hidden bg-gradient-to-br from-brand-aqua from-[-5%] via-brand-teal to-[#008f87] font-sans selection:bg-zap-burst selection:text-zap-night"
  >
    <div
      class="pointer-events-none fixed inset-0 z-0 bg-[radial-gradient(circle_at_18%_20%,rgba(255,255,255,0.22),transparent_50%)]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none fixed inset-0 z-0 bg-[radial-gradient(circle_at_88%_72%,rgba(3,214,186,0.18),transparent_48%)]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none fixed inset-0 z-0 bg-[linear-gradient(to_right,#ffffff18_1px,transparent_1px),linear-gradient(to_bottom,#ffffff18_1px,transparent_1px)] bg-[size:4rem_4rem]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -right-32 top-1/4 z-0 h-96 w-96 rounded-full bg-brand-flame/25 blur-3xl"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -left-24 bottom-1/4 z-0 h-80 w-80 rounded-full bg-zap-burst/28 blur-3xl"
      aria-hidden="true"
    />

    <main class="relative z-10 flex-1">
      <HomeLanding client:load />
    </main>

    <script type="application/ld+json" set:html={faqJsonLd} />
  </div>
</Layout>
