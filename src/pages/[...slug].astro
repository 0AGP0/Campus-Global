---
import Layout from "../layouts/Layout.astro";
import { megaNav } from "@/data/site-nav";

export function getStaticPaths() {
  const paths = new Set<string>();
  for (const m of megaNav) {
    for (const c of m.columns) {
      for (const l of c.links) {
        const h = l.href;
        if (h.startsWith("/") && !h.startsWith("/#") && !h.startsWith("http")) {
          const rest = h.replace(/^\//, "");
          if (rest.length > 0) paths.add(rest);
        }
      }
    }
  }
  return [...paths].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const label = slug
  ? slug
      .split("/")
      .map((s) => s.replace(/-/g, " "))
      .join(" · ")
  : "Sayfa";
---

<Layout
  title={`${label} | Campus Global`}
  description="Campus Global — yurtdışı eğitim danışmanlığı. Sayfa içeriği çok yakında."
>
  <div
    class="min-h-dvh bg-gradient-to-br from-white via-[#e6faf8] to-brand-aqua/20 px-5 py-16 text-zap-ink"
  >
    <div class="mx-auto max-w-2xl">
      <p class="text-[11px] font-black uppercase tracking-[0.28em] text-brand-teal">Campus Global</p>
      <h1 class="mt-3 text-[clamp(1.5rem,4vw,2rem)] font-black uppercase leading-tight tracking-tight">
        Bu sayfa yakında
      </h1>
      <p class="mt-4 text-base font-medium leading-relaxed text-zap-ink/88">
        <span class="font-semibold text-zap-ink">{label}</span> için detay içerik hazırlanıyor. Ana sayfada
        ilgili bölümlere inebilir veya iletişimden bize ulaşabilirsiniz.
      </p>
      <a
        href="/"
        class="mt-10 inline-flex min-h-12 items-center justify-center rounded-full border-4 border-zap-ink bg-zap-burst px-10 py-3 text-sm font-black uppercase text-zap-night shadow-brutal transition hover:brightness-105"
      >
        Ana sayfaya dön
      </a>
    </div>
  </div>
</Layout>
